---
import { getReviews } from '../lib/reviews';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Se ejecuta en servidor — sin fetch interno, llamada directa a la lib
const { reviews, avgRating, totalCount, source } = await getReviews(lang);

const t = {
  es: {
    title: 'Lo que dicen los viajeros',
    poweredBy: 'Reseñas de Google',
    rating: (avg: number, count: number) => `${avg.toFixed(1)} · ${count} reseñas`,
    mockBadge: 'Reseñas de ejemplo',
    mockNote: 'En producción se mostrarán las reseñas reales de Google.',
  },
  en: {
    title: 'What travellers say',
    poweredBy: 'Google Reviews',
    rating: (avg: number, count: number) => `${avg.toFixed(1)} · ${count} reviews`,
    mockBadge: 'Example reviews',
    mockNote: 'Real Google reviews will appear here in production.',
  },
}[lang];

// Colores de avatar ciclando por índice (paleta cálida)
const avatarColors = [
  { bg: '#f2ddd3', color: '#a04020' }, // terracota suave
  { bg: '#f5e9c4', color: '#8a6010' }, // mostaza suave
  { bg: '#dde6d8', color: '#4a6640' }, // salvia suave
  { bg: '#e8ddd5', color: '#6b4f3a' }, // marrón suave
];
---

<section class="reviews section">
  <div class="container">

    <!-- Cabecera de sección -->
    <div class="reviews__head fade-in-up">
      <h2 class="section-title">{t.title}</h2>

      <!-- Indicador de fuente -->
      {source === 'google' && avgRating && totalCount ? (
        <div class="reviews__meta">
          <!-- Logo Google "G" -->
          <svg class="reviews__google-logo" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google" width="20" height="20">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span class="reviews__avg-text">
            <!-- Estrellas con la media -->
            <span class="reviews__stars reviews__stars--summary" aria-hidden="true">
              {Array.from({ length: 5 }, (_, i) => (
                <svg viewBox="0 0 20 20" width="14" height="14" fill={i < Math.round(avgRating) ? 'var(--color-accent)' : 'none'} stroke="var(--color-accent)" stroke-width="1.5">
                  <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/>
                </svg>
              ))}
            </span>
            {t.rating(avgRating, totalCount)}
          </span>
          <span class="reviews__powered">{t.poweredBy}</span>
        </div>
      ) : null}

      <!-- Banner mock (solo cuando no hay credenciales reales) -->
      {source === 'mock' && (
        <div class="reviews__mock-banner" role="note">
          <svg viewBox="0 0 20 20" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <circle cx="10" cy="10" r="8"/><path d="M10 6v4"/><circle cx="10" cy="14" r=".5" fill="currentColor"/>
          </svg>
          <span><strong>{t.mockBadge}.</strong> {t.mockNote}</span>
        </div>
      )}
    </div>

    <!-- Grid de cards -->
    <div class="reviews__grid">
      {reviews.map((review, idx) => {
        const color = avatarColors[idx % avatarColors.length];
        return (
          <article class="review-card fade-in-up">
            <!-- Cabecera: estrellas + logo G -->
            <div class="review-card__top">
              <div class="review-card__stars" aria-label={`${review.rating} de 5 estrellas`}>
                {Array.from({ length: 5 }, (_, i) => (
                  <svg viewBox="0 0 20 20" width="16" height="16"
                    fill={i < review.rating ? 'var(--color-accent)' : 'none'}
                    stroke="var(--color-accent)"
                    stroke-width="1.5"
                    aria-hidden="true">
                    <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/>
                  </svg>
                ))}
              </div>
              {source === 'google' && (
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" class="review-card__g">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              )}
            </div>

            <!-- Texto de la reseña -->
            <p class="review-card__text">"{review.text}"</p>

            <!-- Autor -->
            <div class="review-card__author">
              <div
                class="review-card__avatar"
                style={`background:${color.bg};color:${color.color}`}
                aria-hidden="true"
              >
                {review.initials}
              </div>
              <div class="review-card__author-info">
                <span class="review-card__name">{review.author}</span>
                <span class="review-card__time">{review.relativeTime}</span>
              </div>
            </div>
          </article>
        );
      })}
    </div>

  </div>
</section>

<style>
  .reviews {
    text-align: center;
  }

  /* ── Cabecera ─────────────────────────────────────────────────────────── */
  .reviews__head {
    margin-bottom: 2.5rem;
  }

  .reviews__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding: 0.4rem 1rem;
    background: var(--color-surface);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .reviews__google-logo {
    flex-shrink: 0;
  }

  .reviews__avg-text {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-weight: 600;
  }

  .reviews__stars--summary {
    display: flex;
    gap: 1px;
  }

  .reviews__powered {
    opacity: 0.5;
    font-size: 0.78rem;
    border-left: 1px solid rgba(61,50,40,0.2);
    padding-left: 0.5rem;
    margin-left: 0.1rem;
  }

  /* ── Banner mock ─────────────────────────────────────────────────────── */
  .reviews__mock-banner {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.4rem;
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    background: rgba(212, 168, 67, 0.12);
    border: 1px solid rgba(212, 168, 67, 0.35);
    border-radius: var(--radius-md);
    font-size: 0.8rem;
    color: #7a5c10;
    text-align: left;
    max-width: 480px;
  }

  .reviews__mock-banner svg {
    flex-shrink: 0;
    margin-top: 1px;
    color: #a07810;
  }

  /* ── Grid de cards ───────────────────────────────────────────────────── */
  .reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    text-align: left;
  }

  @media (min-width: 640px) {
    .reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .reviews__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .review-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-warm-sm);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .review-card:hover {
    box-shadow: var(--shadow-warm);
    transform: translateY(-2px);
  }

  /* Cabecera de la card: estrellas + G */
  .review-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .review-card__stars {
    display: flex;
    gap: 2px;
  }

  .review-card__g {
    opacity: 0.7;
    flex-shrink: 0;
  }

  /* Texto */
  .review-card__text {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text);
    opacity: 0.85;
    flex: 1;
    font-style: italic;
  }

  /* Autor */
  .review-card__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(61,50,40,0.08);
  }

  .review-card__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .review-card__author-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .review-card__name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .review-card__time {
    font-size: 0.78rem;
    color: var(--color-text);
    opacity: 0.45;
  }
</style>
