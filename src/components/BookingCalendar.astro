---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div id="booking-calendar" class="cal" data-lang={lang}>
  <div class="cal__loading" id="cal-loading">
    <div class="cal__spinner"></div>
    <span>{lang === 'es' ? 'Cargando disponibilidad...' : 'Loading availability...'}</span>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('booking-calendar');
    if (!container) return;

    const lang = (container.dataset.lang as 'es' | 'en') || 'es';

    const L = {
      es: {
        months: ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'],
        weekdays: ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'],
        available: 'Disponible',
        reserved: 'Reservado',
        past: 'Pasado',
        today: 'Hoy',
        booked: 'Ocupado',
        error: 'No se pudo cargar la disponibilidad.',
        retry: 'Reintentar',
      },
      en: {
        months: ['January','February','March','April','May','June','July','August','September','October','November','December'],
        weekdays: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
        available: 'Available',
        reserved: 'Reserved',
        past: 'Past',
        today: 'Today',
        booked: 'Booked',
        error: 'Could not load availability.',
        retry: 'Try again',
      },
    };

    const t = L[lang] ?? L.es;

    const now = new Date();
    const todayStr = toDateStr(now);
    let currentYear = now.getFullYear();
    let currentMonth = now.getMonth() + 1; // 1-12
    let availabilityData: Record<string, { status: string; price?: number }> = {};
    let isLoading = false;

    function toDateStr(d: Date): string {
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    }

    function isCurrentMonthOrLater(year: number, month: number): boolean {
      return year > now.getFullYear() || (year === now.getFullYear() && month >= now.getMonth() + 1);
    }

    async function fetchAvailability(year: number, month: number) {
      isLoading = true;
      render();
      try {
        const res = await fetch(`/api/availability?year=${year}&month=${month}`);
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json();
        availabilityData = data.days ?? {};
      } catch {
        availabilityData = {};
        renderError();
        return;
      } finally {
        isLoading = false;
      }
      render();
    }

    function navigate(delta: number) {
      const next = { year: currentYear, month: currentMonth + delta };
      if (next.month > 12) { next.month = 1; next.year++; }
      if (next.month < 1)  { next.month = 12; next.year--; }
      // Don't allow going to past months
      if (!isCurrentMonthOrLater(next.year, next.month)) return;
      currentYear = next.year;
      currentMonth = next.month;
      fetchAvailability(currentYear, currentMonth);
    }

    function clearCalendar() {
      container.querySelector('.cal__wrapper')?.remove();
      container.querySelector('.cal__error')?.remove();
    }

    function showLoading(show: boolean) {
      const el = document.getElementById('cal-loading');
      if (el) el.style.display = show ? 'flex' : 'none';
    }

    function renderError() {
      clearCalendar();
      showLoading(false);
      const div = document.createElement('div');
      div.className = 'cal__error';
      div.innerHTML = `<p>${t.error}</p><button class="cal__retry">${t.retry}</button>`;
      div.querySelector('.cal__retry')!.addEventListener('click', () => fetchAvailability(currentYear, currentMonth));
      container.appendChild(div);
    }

    function render() {
      showLoading(isLoading);
      clearCalendar();
      if (isLoading) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'cal__wrapper';

      // ── Header ──────────────────────────────────────────────────────────
      const header = document.createElement('div');
      header.className = 'cal__header';

      const prevBtn = document.createElement('button');
      prevBtn.className = 'cal__nav';
      prevBtn.setAttribute('aria-label', 'Mes anterior');
      prevBtn.disabled = !isCurrentMonthOrLater(currentYear, currentMonth - 1 < 1 ? currentMonth - 1 + 12 : currentMonth - 1)
        || (currentYear === now.getFullYear() && currentMonth === now.getMonth() + 1);
      prevBtn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>`;
      prevBtn.addEventListener('click', () => navigate(-1));

      const monthTitle = document.createElement('h3');
      monthTitle.className = 'cal__month-title';
      monthTitle.textContent = `${t.months[currentMonth - 1]} ${currentYear}`;

      const nextBtn = document.createElement('button');
      nextBtn.className = 'cal__nav';
      nextBtn.setAttribute('aria-label', 'Mes siguiente');
      nextBtn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>`;
      nextBtn.addEventListener('click', () => navigate(1));

      header.append(prevBtn, monthTitle, nextBtn);
      wrapper.appendChild(header);

      // ── Weekday labels ───────────────────────────────────────────────────
      const weekdays = document.createElement('div');
      weekdays.className = 'cal__weekdays';
      t.weekdays.forEach(d => {
        const cell = document.createElement('div');
        cell.className = 'cal__weekday';
        cell.textContent = d;
        weekdays.appendChild(cell);
      });
      wrapper.appendChild(weekdays);

      // ── Day grid ─────────────────────────────────────────────────────────
      const grid = document.createElement('div');
      grid.className = 'cal__grid';

      const daysInMonth = new Date(currentYear, currentMonth, 0).getDate();
      // Monday-first offset (0=Mon … 6=Sun)
      let offset = new Date(currentYear, currentMonth - 1, 1).getDay();
      offset = offset === 0 ? 6 : offset - 1;

      for (let i = 0; i < offset; i++) {
        const empty = document.createElement('div');
        empty.className = 'cal__cell cal__cell--empty';
        grid.appendChild(empty);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${currentYear}-${String(currentMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const date = new Date(currentYear, currentMonth - 1, d);
        const isPast = dateStr < todayStr;
        const isToday = dateStr === todayStr;
        const dayData = availabilityData[dateStr];

        const cell = document.createElement('div');
        cell.className = 'cal__cell';

        // Day number
        const num = document.createElement('span');
        num.className = 'cal__day-num';
        num.textContent = String(d);
        cell.appendChild(num);

        if (isToday) {
          cell.classList.add('cal__cell--today');
          const badge = document.createElement('span');
          badge.className = 'cal__badge cal__badge--today';
          badge.textContent = t.today;
          cell.appendChild(badge);
        } else if (isPast) {
          cell.classList.add('cal__cell--past');
        } else if (dayData?.status === 'reserved') {
          cell.classList.add('cal__cell--reserved');
          const badge = document.createElement('span');
          badge.className = 'cal__badge cal__badge--reserved';
          badge.textContent = t.booked;
          cell.appendChild(badge);
        } else {
          // available (or no data yet)
          cell.classList.add('cal__cell--available');
          if (dayData?.price) {
            const price = document.createElement('span');
            price.className = 'cal__price';
            price.textContent = `${dayData.price}€`;
            cell.appendChild(price);
          }
        }

        grid.appendChild(cell);
      }

      wrapper.appendChild(grid);

      // ── Legend ───────────────────────────────────────────────────────────
      const legend = document.createElement('div');
      legend.className = 'cal__legend';
      const items = [
        { cls: 'cal__dot--available', label: t.available },
        { cls: 'cal__dot--reserved',  label: t.reserved  },
        { cls: 'cal__dot--past',      label: t.past      },
      ];
      items.forEach(({ cls, label }) => {
        const item = document.createElement('div');
        item.className = 'cal__legend-item';
        item.innerHTML = `<span class="cal__dot ${cls}"></span><span>${label}</span>`;
        legend.appendChild(item);
      });
      wrapper.appendChild(legend);

      container.appendChild(wrapper);
    }

    // Initial load
    fetchAvailability(currentYear, currentMonth);
  });
</script>

<style is:global>
  /* ── Container ─────────────────────────────────────────────────────────── */
  .cal {
    max-width: 680px;
    margin: 0 auto;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-warm);
  }

  /* ── Loading ────────────────────────────────────────────────────────────── */
  .cal__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 4rem 1rem;
    color: var(--color-text);
    opacity: 0.65;
    font-size: 0.95rem;
  }

  .cal__spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(61,50,40,0.15);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: cal-spin 0.75s linear infinite;
  }

  @keyframes cal-spin { to { transform: rotate(360deg); } }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  .cal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .cal__month-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .cal__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .cal__nav:hover:not(:disabled) {
    background: var(--color-primary);
    color: #fff;
    transform: scale(1.1);
  }

  .cal__nav:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  /* ── Weekday headers ────────────────────────────────────────────────────── */
  .cal__weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-bottom: 6px;
  }

  .cal__weekday {
    text-align: center;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    opacity: 0.4;
    padding: 0.4rem 0;
  }

  /* ── Day grid ───────────────────────────────────────────────────────────── */
  .cal__grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 5px;
  }

  /* Base cell */
  .cal__cell {
    min-height: 56px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 6px 3px;
    position: relative;
    border: 1.5px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .cal__cell--empty {
    background: transparent;
    border: none;
  }

  /* Available */
  .cal__cell--available {
    background: rgba(139, 158, 126, 0.2);
    border-color: rgba(139, 158, 126, 0.35);
    cursor: default;
  }

  .cal__cell--available:hover {
    border-color: var(--color-sage);
    box-shadow: 0 2px 8px rgba(139, 158, 126, 0.3);
  }

  /* Reserved */
  .cal__cell--reserved {
    background: rgba(196, 101, 58, 0.12);
    border-color: rgba(196, 101, 58, 0.3);
    cursor: not-allowed;
  }

  /* Past */
  .cal__cell--past {
    background: rgba(61, 50, 40, 0.05);
    border-color: transparent;
    cursor: not-allowed;
    opacity: 0.45;
  }

  /* Today */
  .cal__cell--today {
    background: rgba(212, 168, 67, 0.18);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
  }

  /* ── Cell content ───────────────────────────────────────────────────────── */
  .cal__day-num {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }

  .cal__cell--past .cal__day-num {
    font-weight: 400;
  }

  .cal__price {
    font-size: 0.7rem;
    font-weight: 700;
    color: #5a7a4e;   /* sage green, darker for contrast */
    line-height: 1;
  }

  .cal__badge {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
    border-radius: 4px;
    padding: 1px 4px;
  }

  .cal__badge--today {
    background: var(--color-accent);
    color: #fff;
  }

  .cal__badge--reserved {
    background: rgba(196, 101, 58, 0.2);
    color: var(--color-primary);
  }

  /* ── Legend ─────────────────────────────────────────────────────────────── */
  .cal__legend {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(61, 50, 40, 0.1);
  }

  .cal__legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text);
    opacity: 0.7;
  }

  .cal__dot {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    border: 1.5px solid transparent;
    flex-shrink: 0;
  }

  .cal__dot--available {
    background: rgba(139, 158, 126, 0.25);
    border-color: rgba(139, 158, 126, 0.5);
  }

  .cal__dot--reserved {
    background: rgba(196, 101, 58, 0.15);
    border-color: rgba(196, 101, 58, 0.4);
  }

  .cal__dot--past {
    background: rgba(61, 50, 40, 0.08);
    border-color: rgba(61, 50, 40, 0.15);
  }

  /* ── Error state ─────────────────────────────────────────────────────────── */
  .cal__error {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text);
    opacity: 0.7;
  }

  .cal__error p {
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .cal__retry {
    background: var(--color-primary);
    color: #fff;
    padding: 0.6rem 1.75rem;
    border-radius: var(--radius-pill);
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    border: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .cal__retry:hover {
    transform: scale(1.03);
    opacity: 0.92;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (min-width: 480px) {
    .cal__cell {
      min-height: 62px;
      gap: 4px;
      padding: 6px 4px;
    }

    .cal__day-num {
      font-size: 0.9rem;
    }

    .cal__price {
      font-size: 0.75rem;
    }

    .cal__badge {
      font-size: 0.62rem;
    }
  }

  @media (min-width: 768px) {
    .cal {
      padding: 2rem 2.5rem;
    }

    .cal__grid {
      gap: 6px;
    }

    .cal__cell {
      min-height: 72px;
      gap: 5px;
      padding: 8px 6px;
    }

    .cal__day-num {
      font-size: 1rem;
    }

    .cal__price {
      font-size: 0.8rem;
    }

    .cal__badge {
      font-size: 0.65rem;
      padding: 2px 5px;
    }

    .cal__month-title {
      font-size: 1.45rem;
    }
  }
</style>
