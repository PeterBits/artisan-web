---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const DEFAULT_WHATSAPP_NUMBER = '34722185903';
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? DEFAULT_WHATSAPP_NUMBER;
const whatsappHref = `https://wa.me/${whatsappNumber}`;
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <span class="footer__logo-text">Rodando Libre</span>
      <p class="footer__tagline">{t.footer.tagline}</p>
    </div>

    <div class="footer__contact">
      <a href={whatsappHref} class="btn-whatsapp footer__wa-btn" target="_blank" rel="noopener noreferrer">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        {t.footer.whatsapp}
      </a>
    </div>

    <div class="footer__social">
      <a href="https://instagram.com/rodandolibre" class="footer__instagram-link" target="_blank" rel="noopener noreferrer">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        {t.footer.instagram}
      </a>
      <p class="footer__copyright">&copy; {t.footer.copyright}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-footer-bg);
    padding: 3rem 0 2rem;
    margin-top: 2rem;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    text-align: center;
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer__tagline {
    font-size: 0.9rem;
    color: var(--color-text);
    opacity: 0.7;
    line-height: 1.5;
  }

  .footer__contact {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .footer__wa-btn {
    font-size: 0.95rem;
    padding: 0.65rem 1.8rem;
  }

  .footer__social {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer__instagram-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color var(--transition);
  }

  .footer__instagram-link:hover {
    color: var(--color-primary);
  }

  .footer__copyright {
    font-size: 0.8rem;
    color: var(--color-text);
    opacity: 0.5;
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr auto 1fr;
      text-align: left;
      align-items: center;
    }

    .footer__social {
      align-items: flex-end;
    }
  }
</style>
