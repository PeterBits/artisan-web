---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import vanData from '../data/van-data.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const priceLabel = lang === 'es' ? 'Tarifa' : 'Rate';
const seasonLabels = {
  low:    lang === 'es' ? 'Temporada baja'   : 'Low season',
  mid:    lang === 'es' ? 'Temporada media'  : 'Mid season',
  summer: lang === 'es' ? 'Temporada alta'   : 'High season',
};

const availabilityLabel = vanData.pricing.availabilityLabel[lang];
const seasonsMessage = vanData.pricing.seasonsMessage[lang];
const conditionsSummary = vanData.booking.conditionsSummary[lang];

const priceCards = [
  { key: 'low',    label: seasonLabels.low,    highlighted: false },
  { key: 'mid',    label: seasonLabels.mid,    highlighted: true  },
  { key: 'summer', label: seasonLabels.summer, highlighted: false },
];
---

<section class="price-info section--compact">
  <div class="price-info__inner container">
    <p class="price-info__intro fade-in-up">{seasonsMessage}</p>
    <div class="price-info__cards">
      {priceCards.map((card) => (
        <div class={`price-card fade-in-up ${card.highlighted ? 'price-card--highlighted' : ''}`}>
          <span class="price-card__label">{card.label}</span>
          <span class="price-card__price">{availabilityLabel}</span>
        </div>
      ))}
    </div>

    <div class="price-info__conditions fade-in-up">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="16" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
      <p class="price-info__conditions-text">{conditionsSummary}</p>
    </div>
  </div>
</section>

<style>
  .price-info__intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 1.5rem;
    color: var(--color-text);
    opacity: 0.8;
    font-size: 1rem;
  }

  .price-info__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .price-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem;
    text-align: center;
    border: 2px solid transparent;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .price-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-warm);
  }

  .price-card--highlighted {
    border-color: var(--color-primary);
    position: relative;
  }

  .price-card__label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    opacity: 0.75;
    margin-bottom: 0.5rem;
  }

  .price-card__price {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }

  .price-info__conditions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 2rem;
    padding: 1rem 1.5rem;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .price-info__conditions svg {
    flex-shrink: 0;
  }

  .price-info__conditions-text {
    font-size: 0.95rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    .price-info__cards {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .price-card--highlighted {
      transform: scale(1.05);
    }

    .price-card--highlighted:hover {
      transform: scale(1.05) translateY(-3px);
    }

    .price-card__price {
      font-size: 1.5rem;
    }
  }
</style>
