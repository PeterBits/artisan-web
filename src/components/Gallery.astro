---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const GALLERY_IMAGES = [
  '/assets/foto exterior lateral campo verde.png',
  '/assets/foto dentro alante retocada.png',
  '/assets/foto dentro atras retocada.png',
  '/assets/foto nevera.png',
] as const;
---

<section class="gallery section">
  <div class="gallery__inner container">
    <h2 class="section-title fade-in-up">{t.gallery.title}</h2>
    <p class="section-subtitle fade-in-up">{t.gallery.subtitle}</p>

    <!-- Decorative waves -->
    <svg class="gallery__waves svg-decoration fade-in-up" width="200" height="20" viewBox="0 0 200 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0 10 C20 2, 40 18, 60 10 C80 2, 100 18, 120 10 C140 2, 160 18, 180 10 C190 6, 195 8, 200 10" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
      <path d="M0 16 C20 8, 40 24, 60 16 C80 8, 100 24, 120 16 C140 8, 160 24, 180 16 C190 12, 195 14, 200 16" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" opacity="0.25"/>
    </svg>

    <div class="gallery__grid">
      {GALLERY_IMAGES.map((src, index) => (
        <figure class="gallery-card fade-in-up">
          <img
            src={src}
            alt={t.gallery.images[index].alt}
            class="gallery-card__image"
            loading="lazy"
            width="600"
            height="450"
          />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    text-align: center;
  }

  .gallery__waves {
    margin: 0 auto 2rem;
    display: block;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .gallery-card {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-warm-sm);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .gallery-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-warm);
  }

  .gallery-card__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  @media (min-width: 768px) {
    .gallery__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
</style>
